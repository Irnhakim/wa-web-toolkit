{
  "manifest_version": 3,
  "name": "WA Web Toolkit (Baileys Client)",
  "version": "1.0.0",
  "description": "Send Interactive Buttons, Custom Link Previews, and Carousels on WhatsApp Web via Baileys backend.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "ui.css"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "WA Web Toolkit"
  }
}
